@using Microsoft.AspNetCore.Components.Authorization

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">🍴 Rezept Hopper</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                        <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Startseite
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="rezepte">
                        <span class="bi bi-book-fill-nav-menu" aria-hidden="true"></span> Meine Rezepte
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="rezepte/hinzufuegen">
                        <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Rezept hinzufügen
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="ordner">
                        <span class="bi bi-folder-fill-nav-menu" aria-hidden="true"></span> Ordner
                    </NavLink>
                </div>
                <hr class="border-secondary my-2 mx-3" />
                <div class="nav-item px-3">
                    <form method="post" action="/account/logout">
                        <AntiforgeryToken />
                        <button type="submit" class="nav-link btn btn-link text-start w-100 text-danger">
                            Abmelden (@context.User.Identity?.Name)
                        </button>
                    </form>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        Anmelden
                    </NavLink>
                </div>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="registrieren">
                        Registrieren
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

