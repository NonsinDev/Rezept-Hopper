@page "/rezepte/{Id:int}/bearbeiten"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject Rezept_Hopper.Services.RecipeService RecipeService
@inject Rezept_Hopper.Services.CurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>Rezept bearbeiten – Rezept Hopper</PageTitle>

<h2 class="mb-4">✏️ Rezept bearbeiten</h2>

@if (Recipe is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>
}
else
{
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="alert alert-danger">@ErrorMessage</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-body p-4">
            <h5 class="mb-3">Grundinformationen</h5>
            <div class="mb-3">
                <label class="form-label">Titel</label>
                <input type="text" class="form-control" @bind="Recipe.Title" />
            </div>
            <div class="mb-3">
                <label class="form-label">Beschreibung</label>
                <textarea class="form-control" rows="3" @bind="Recipe.Description"></textarea>
            </div>
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Vorbereitungszeit (Min.)</label>
                    <input type="number" class="form-control" @bind="Recipe.PrepTimeMinutes" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Kochzeit (Min.)</label>
                    <input type="number" class="form-control" @bind="Recipe.CookTimeMinutes" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Portionen</label>
                    <input type="number" class="form-control" @bind="Recipe.Servings" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Schwierigkeit</label>
                    <select class="form-select" @bind="Recipe.Difficulty">
                        <option value="">– wählen –</option>
                        <option>Einfach</option>
                        <option>Mittel</option>
                        <option>Schwer</option>
                    </select>
                </div>
            </div>
            <div class="mt-3">
                <label class="form-label">Küche</label>
                <input type="text" class="form-control" @bind="Recipe.Cuisine" />
            </div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body p-4">
            <h5 class="mb-3">Zutaten</h5>
            @foreach (var (ing, i) in Recipe.Ingredients.ToList().Select((x, i) => (x, i)))
            {
                <div class="row g-2 mb-2 align-items-center">
                    <div class="col-md-5">
                        <input type="text" class="form-control" placeholder="Zutat" @bind="ing.Name" />
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Menge" @bind="ing.Amount" />
                    </div>
                    <div class="col-md-3">
                        <input type="text" class="form-control" placeholder="Einheit" @bind="ing.Unit" />
                    </div>
                    <div class="col-md-1">
                        <button class="btn btn-outline-danger btn-sm w-100"
                                @onclick="() => Recipe.Ingredients.Remove(ing)">✕</button>
                    </div>
                </div>
            }
            <button class="btn btn-outline-secondary btn-sm mt-2"
                    @onclick="() => Recipe.Ingredients.Add(new Rezept_Hopper.Data.Models.Ingredient { RecipeId = Recipe.Id })">
                + Zutat hinzufügen
            </button>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-body p-4">
            <h5 class="mb-3">Zubereitung</h5>
            @foreach (var (step, i) in Recipe.Steps.ToList().Select((x, i) => (x, i)))
            {
                <div class="d-flex gap-2 mb-2 align-items-start">
                    <span class="badge bg-primary mt-2" style="min-width:28px">@(i + 1)</span>
                    <textarea class="form-control" rows="2"
                              @bind="step.Instruction"></textarea>
                    <button class="btn btn-outline-danger btn-sm mt-1"
                            @onclick="() => Recipe.Steps.Remove(step)">✕</button>
                </div>
            }
            <button class="btn btn-outline-secondary btn-sm mt-2"
                    @onclick="() => Recipe.Steps.Add(new Rezept_Hopper.Data.Models.RecipeStep { RecipeId = Recipe.Id, StepNumber = Recipe.Steps.Count + 1 })">
                + Schritt hinzufügen
            </button>
        </div>
    </div>

    <div class="d-flex gap-2">
        <a href="/rezepte/@Recipe.Id" class="btn btn-outline-secondary">← Abbrechen</a>
        <button class="btn btn-success" @onclick="SaveAsync" disabled="@IsSaving">
            @if (IsSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
            Speichern
        </button>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Rezept_Hopper.Data.Models.Recipe? Recipe { get; set; }
    private string? ErrorMessage { get; set; }
    private bool IsSaving { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.UserId.HasValue) return;
        Recipe = await RecipeService.GetRecipeAsync(Id, CurrentUser.UserId.Value);
    }

    private async Task SaveAsync()
    {
        if (Recipe is null) return;
        IsSaving = true;
        await RecipeService.UpdateRecipeAsync(Recipe);
        IsSaving = false;
        Nav.NavigateTo($"/rezepte/{Recipe.Id}");
    }
}
