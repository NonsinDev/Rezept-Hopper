@page "/ordner/{Id:int}"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inject Rezept_Hopper.Services.FolderService FolderService
@inject Rezept_Hopper.Services.RecipeService RecipeService
@inject Rezept_Hopper.Services.CurrentUserService CurrentUser
@inject NavigationManager Nav

<PageTitle>@(Folder?.Name ?? "Ordner") – Rezept Hopper</PageTitle>

@if (Folder is null && !NotFound)
{
    <div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>
}
else if (NotFound)
{
    <div class="alert alert-warning">Ordner nicht gefunden oder kein Zugriff.</div>
}
else if (Folder is not null)
{
    <div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
        <div>
            <a href="/ordner" class="text-muted text-decoration-none small">← Alle Ordner</a>
            <h2 class="mt-1">📁 @Folder.Name</h2>
            @if (!string.IsNullOrEmpty(Folder.Description))
            {
                <p class="text-muted">@Folder.Description</p>
            }
        </div>
        @if (IsOwner)
        {
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick="() => ShowShare = !ShowShare">👥 Teilen</button>
                <button class="btn btn-outline-danger btn-sm" @onclick="DeleteFolderAsync">🗑️ Löschen</button>
            </div>
        }
    </div>

    @if (IsOwner && ShowShare)
    {
        <div class="card shadow-sm mb-4 border-info">
            <div class="card-header fw-bold">Ordner teilen</div>
            <div class="card-body p-3">
                @if (!string.IsNullOrEmpty(ShareError))
                {
                    <div class="alert alert-danger py-2">@ShareError</div>
                }
                @if (!string.IsNullOrEmpty(ShareSuccess))
                {
                    <div class="alert alert-success py-2">@ShareSuccess</div>
                }
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Benutzername</label>
                        <input type="text" class="form-control" @bind="ShareUsername" placeholder="Benutzername eingeben" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Berechtigung</label>
                        <select class="form-select" @bind="ShareCanEdit">
                            <option value="false">Nur lesen</option>
                            <option value="true">Lesen & Bearbeiten</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" @onclick="ShareAsync">Teilen</button>
                    </div>
                </div>

                @if (Folder.Shares.Count > 0)
                {
                    <hr />
                    <h6 class="text-muted">Aktuell geteilt mit:</h6>
                    <ul class="list-group list-group-flush">
                        @foreach (var share in Folder.Shares)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <span>@share.SharedWithUser.Username <span class="badge @(share.CanEdit ? "bg-warning text-dark" : "bg-secondary") ms-2">@(share.CanEdit ? "Bearbeiten" : "Lesen")</span></span>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveShareAsync(share.SharedWithUserId)">Entfernen</button>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    }

    @if (!CanEdit && !IsOwner)
    {
        <div class="alert alert-info py-2 small">Du hast nur Lesezugriff auf diesen Ordner.</div>
    }

    <h5 class="text-muted mb-3">Rezepte in diesem Ordner</h5>

    @if (Folder.FolderRecipes.Count == 0)
    {
        <p class="text-muted">Noch keine Rezepte in diesem Ordner.</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-3 mb-4">
            @foreach (var fr in Folder.FolderRecipes)
            {
                <div class="col">
                    <div class="card shadow-sm h-100">
                        <div class="card-body" style="cursor:pointer" @onclick="() => GoToRecipe(fr.Recipe.Id)">
                            <h6 class="card-title">@fr.Recipe.Title</h6>
                            @if (!string.IsNullOrEmpty(fr.Recipe.Description))
                            {
                                <p class="card-text text-muted small">@(fr.Recipe.Description.Length > 80 ? fr.Recipe.Description[..80] + "…" : fr.Recipe.Description)</p>
                            }
                        </div>
                        @if (IsOwner || CanEdit)
                        {
                            <div class="card-footer">
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveRecipeAsync(fr.Recipe.Id)">Entfernen</button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

    @if (IsOwner || CanEdit)
    {
        <div class="card shadow-sm">
            <div class="card-header">Rezept zum Ordner hinzufügen</div>
            <div class="card-body">
                @if (AllRecipes is null)
                {
                    <span class="text-muted">Lade Rezepte…</span>
                }
                else
                {
                    <div class="row g-2 align-items-end">
                        <div class="col-md-8">
                            <select class="form-select" @bind="SelectedRecipeId">
                                <option value="0">– Rezept auswählen –</option>
                                @foreach (var r in AvailableRecipes)
                                {
                                    <option value="@r.Id">@r.Title</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-primary w-100" @onclick="AddRecipeAsync" disabled="@(SelectedRecipeId == 0)">Hinzufügen</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public int Id { get; set; }

    private Rezept_Hopper.Data.Models.Folder? Folder { get; set; }
    private bool IsOwner { get; set; }
    private bool CanEdit { get; set; }
    private bool NotFound { get; set; }
    private bool ShowShare { get; set; }
    private string ShareUsername { get; set; } = string.Empty;
    private bool ShareCanEdit { get; set; }
    private string? ShareError { get; set; }
    private string? ShareSuccess { get; set; }
    private List<Rezept_Hopper.Data.Models.Recipe>? AllRecipes { get; set; }
    private int SelectedRecipeId { get; set; }

    private IEnumerable<Rezept_Hopper.Data.Models.Recipe> AvailableRecipes =>
        AllRecipes?.Where(r => !Folder!.FolderRecipes.Any(fr => fr.RecipeId == r.Id)) ?? [];

    protected override async Task OnInitializedAsync()
    {
        if (!CurrentUser.UserId.HasValue) return;

        Folder = await FolderService.GetFolderAsync(Id, CurrentUser.UserId.Value);
        if (Folder is not null)
        {
            IsOwner = true;
            CanEdit = true;
        }
        else
        {
            var (sharedFolder, canEdit) = await FolderService.GetSharedFolderAsync(Id, CurrentUser.UserId.Value);
            Folder = sharedFolder;
            CanEdit = canEdit;
        }

        if (Folder is null) { NotFound = true; return; }

        if (IsOwner || CanEdit)
            AllRecipes = await RecipeService.GetUserRecipesAsync(CurrentUser.UserId.Value);
    }

    private async Task AddRecipeAsync()
    {
        if (!CurrentUser.UserId.HasValue || SelectedRecipeId == 0) return;
        await FolderService.AddRecipeToFolderAsync(Id, SelectedRecipeId, CurrentUser.UserId.Value);
        Folder = await FolderService.GetFolderAsync(Id, CurrentUser.UserId.Value)
                 ?? (await FolderService.GetSharedFolderAsync(Id, CurrentUser.UserId.Value)).Folder;
        SelectedRecipeId = 0;
    }

    private async Task RemoveRecipeAsync(int recipeId)
    {
        if (!CurrentUser.UserId.HasValue) return;
        await FolderService.RemoveRecipeFromFolderAsync(Id, recipeId, CurrentUser.UserId.Value);
        Folder = await FolderService.GetFolderAsync(Id, CurrentUser.UserId.Value)
                 ?? (await FolderService.GetSharedFolderAsync(Id, CurrentUser.UserId.Value)).Folder;
    }

    private async Task ShareAsync()
    {
        ShareError = null; ShareSuccess = null;
        if (!CurrentUser.UserId.HasValue) return;
        var (success, error) = await FolderService.ShareFolderAsync(Id, ShareUsername, ShareCanEdit, CurrentUser.UserId.Value);
        if (success)
        {
            ShareSuccess = $"Ordner erfolgreich mit \"{ShareUsername}\" geteilt.";
            ShareUsername = string.Empty;
            Folder = await FolderService.GetFolderAsync(Id, CurrentUser.UserId.Value);
        }
        else
        {
            ShareError = error;
        }
    }

    private async Task RemoveShareAsync(int sharedUserId)
    {
        if (!CurrentUser.UserId.HasValue) return;
        await FolderService.RemoveShareAsync(Id, sharedUserId, CurrentUser.UserId.Value);
        Folder = await FolderService.GetFolderAsync(Id, CurrentUser.UserId.Value);
    }

    private async Task DeleteFolderAsync()
    {
        if (!CurrentUser.UserId.HasValue) return;
        await FolderService.DeleteFolderAsync(Id, CurrentUser.UserId.Value);
        Nav.NavigateTo("/ordner");
    }

    private void GoToRecipe(int id) => Nav.NavigateTo("/rezepte/" + id);
}
